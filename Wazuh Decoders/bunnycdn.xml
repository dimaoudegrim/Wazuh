<!-- Modify it at your will. -->
<decoder name="bunnycdn">
  <prematch>\d+\D\d*\D\d*\w\d*\D\d*\D\d*\.\d*\D\d*\D\d* BunnyCDN</prematch>
</decoder>

<decoder name="bunnycdn-child">
  <parent>bunnycdn</parent>
  <regex offset="after_parent">\d+ \S+ (\S+) - (\S+)\|(\d+)\|\d+\|(\d+)\|\d+\|(\S+)\|(\S+)\|(\S+)\|(\.*)\|(\.*)\|\.*\|(\.*)</regex>
  <order>layer, cache, code, bytes, IP,referer.url, site, edge-location, user-agent, country</order>
</decoder>
